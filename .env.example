# CRITO configuration — copy to ".env" (same dir you run uvicorn from) and edit.
# Every setting is also overridable as a real environment variable of the same name.
# Rule: CRITO_<FIELD_IN_UPPER_CASE>.  Site identity/telescopes live in observatory.yaml.
# NOTE: .env is gitignored — keep secrets here, not in observatory.yaml or git.

# ── INDI server this backend connects to (the site's hardware hub) ───────────
#CRITO_INDI_HOST=localhost
#CRITO_INDI_PORT=7624
#CRITO_OBSERVATORY_FILE=observatory.yaml

# ── Auth / RBAC ─────────────────────────────────────────────────────────────
# Use the SAME secret on EVERY site backend so one login works across all sites.
CRITO_AUTH_SECRET=change-me-to-a-long-random-string
CRITO_ADMIN_USER=admin
CRITO_ADMIN_PASSWORD=change-this-after-first-login

# ── Weather API (auto-feeds the safety monitor) ─────────────────────────────
# open-meteo = free, no key (default). openweather = needs a key. "" = disable.
CRITO_WEATHER_API=open-meteo
#CRITO_WEATHER_API=openweather
#CRITO_WEATHER_API_KEY=your-openweathermap-key
#CRITO_WEATHER_POLL_S=600
#CRITO_WEATHER_DEVICE=                # optional INDI weather device label (takes priority)

# ── Safety thresholds ───────────────────────────────────────────────────────
#CRITO_SAFETY_ENABLED=true
#CRITO_SAFETY_STALE_S=180
#CRITO_SAFETY_CLEAR_DELAY_S=120
#CRITO_SAFETY_HUMIDITY_WARN=85
#CRITO_SAFETY_HUMIDITY_UNSAFE=95
#CRITO_SAFETY_WIND_UNSAFE=40          # km/h
#CRITO_SAFETY_CLOUD_UNSAFE=90         # %

# ── Execution ───────────────────────────────────────────────────────────────
# Master switch for unattended auto-dispatch — keep OFF until you trust safety.
CRITO_AUTO_EXECUTE=false
#CRITO_DEFAULT_EXPTIME_S=120
#CRITO_DEFAULT_COUNT=5

# ── PHD2 guiding (edge node) ────────────────────────────────────────────────
#CRITO_PHD2_HOST=                     # empty = use CRITO_INDI_HOST
#CRITO_PHD2_PORT=4400

# ── Plate-solve + autofocus (ASTAP) ─────────────────────────────────────────
# Install ASTAP + a star DB on the edge node. Set the focal length in
# observatory.yaml (equipment.telescope.focal_length_mm) for a fast FOV hint.
#CRITO_SOLVER=astap                   # "astap" or "none" (disables center/autofocus)
#CRITO_ASTAP_PATH=astap               # binary on PATH, or an absolute path
#CRITO_SOLVE_DB=                      # ASTAP star DB dir (-d); blank = default install
#CRITO_CENTER_TOLERANCE_ARCSEC=30
#CRITO_CENTER_MAX_ITER=3
#CRITO_SOLVE_EXPOSURE_S=4
#CRITO_SOLVE_SCIENCE_FRAMES=false     # also solve each LIGHT frame → write a WCS (slower)
#CRITO_AF_EXPOSURE_S=3
#CRITO_AF_STEP_SIZE=100               # focuser steps between samples
#CRITO_AF_STEPS=9                     # samples per sweep (odd)
#CRITO_AF_BACKLASH=200                # steps for one-directional final approach
#CRITO_AF_MIN_STARS=5
# Calibration: opaque "dark" filter slot moved in for dark/bias frames.
#CRITO_DARK_FILTER_SLOT=0             # 0 = auto-detect a slot named dark/blank/opaque

# ── ALeRCE transient broker ─────────────────────────────────────────────────
#CRITO_ALERCE_CLASSIFIER=stamp_classifier
#CRITO_ALERCE_CLASSES=SN,AGN,VS
#CRITO_ALERCE_PROBABILITY=0.4
#CRITO_ALT_MIN_DEG=30                 # observability horizon limit

# ── Slack / email approval (optional; left blank = disabled) ────────────────
#CRITO_SLACK_BOT_TOKEN=xoxb-...
#CRITO_SLACK_APP_TOKEN=xapp-...
#CRITO_SLACK_CHANNEL=C0123456789
#CRITO_SMTP_HOST=
#CRITO_SMTP_PORT=587
#CRITO_SMTP_USER=
#CRITO_SMTP_PASSWORD=
#CRITO_SMTP_FROM=
#CRITO_SMTP_TO=
#CRITO_APPROVE_SECRET=change-me
#CRITO_API_BASE_URL=http://localhost:8000
