# CASSA configuration — copy to ".env" (same dir you run uvicorn from) and edit.
# Every setting is also overridable as a real environment variable of the same name.
# Rule: CASSA_<FIELD_IN_UPPER_CASE>.  Site identity/telescopes live in observatory.yaml.
# NOTE: .env is gitignored — keep secrets here, not in observatory.yaml or git.

# ── INDI server this backend connects to (the site's hardware hub) ───────────
#CASSA_INDI_HOST=localhost
#CASSA_INDI_PORT=7624
#CASSA_OBSERVATORY_FILE=observatory.yaml

# ── Auth / RBAC ─────────────────────────────────────────────────────────────
# Use the SAME secret on EVERY site backend so one login works across all sites.
CASSA_AUTH_SECRET=change-me-to-a-long-random-string
CASSA_ADMIN_USER=admin
CASSA_ADMIN_PASSWORD=change-this-after-first-login

# ── Weather API (auto-feeds the safety monitor) ─────────────────────────────
# open-meteo = free, no key (default). openweather = needs a key. "" = disable.
CASSA_WEATHER_API=open-meteo
#CASSA_WEATHER_API=openweather
#CASSA_WEATHER_API_KEY=your-openweathermap-key
#CASSA_WEATHER_POLL_S=600
#CASSA_WEATHER_DEVICE=                # optional INDI weather device label (takes priority)

# ── Safety thresholds ───────────────────────────────────────────────────────
#CASSA_SAFETY_ENABLED=true
#CASSA_SAFETY_STALE_S=180
#CASSA_SAFETY_CLEAR_DELAY_S=120
#CASSA_SAFETY_HUMIDITY_WARN=85
#CASSA_SAFETY_HUMIDITY_UNSAFE=95
#CASSA_SAFETY_WIND_UNSAFE=40          # km/h
#CASSA_SAFETY_CLOUD_UNSAFE=90         # %

# ── Execution ───────────────────────────────────────────────────────────────
# Master switch for unattended auto-dispatch — keep OFF until you trust safety.
CASSA_AUTO_EXECUTE=false
#CASSA_DEFAULT_EXPTIME_S=120
#CASSA_DEFAULT_COUNT=5

# ── PHD2 guiding (edge node) ────────────────────────────────────────────────
#CASSA_PHD2_HOST=                     # empty = use CASSA_INDI_HOST
#CASSA_PHD2_PORT=4400

# ── Plate-solve + autofocus (ASTAP) ─────────────────────────────────────────
# Install ASTAP + a star DB on the edge node. Set the focal length in
# observatory.yaml (equipment.telescope.focal_length_mm) for a fast FOV hint.
#CASSA_SOLVER=astap                   # "astap" or "none" (disables center/autofocus)
#CASSA_ASTAP_PATH=astap               # binary on PATH, or an absolute path
#CASSA_SOLVE_DB=                      # ASTAP star DB dir (-d); blank = default install
#CASSA_CENTER_TOLERANCE_ARCSEC=30
#CASSA_CENTER_MAX_ITER=3
#CASSA_SOLVE_EXPOSURE_S=4
#CASSA_SOLVE_SCIENCE_FRAMES=false     # also solve each LIGHT frame → write a WCS (slower)
#CASSA_AF_EXPOSURE_S=3
#CASSA_AF_STEP_SIZE=100               # focuser steps between samples
#CASSA_AF_STEPS=9                     # samples per sweep (odd)
#CASSA_AF_BACKLASH=200                # steps for one-directional final approach
#CASSA_AF_MIN_STARS=5
# Calibration: opaque "dark" filter slot moved in for dark/bias frames.
#CASSA_DARK_FILTER_SLOT=0             # 0 = auto-detect a slot named dark/blank/opaque

# ── ALeRCE transient broker ─────────────────────────────────────────────────
#CASSA_ALERCE_CLASSIFIER=stamp_classifier
#CASSA_ALERCE_CLASSES=SN,AGN,VS
#CASSA_ALERCE_PROBABILITY=0.4
#CASSA_ALT_MIN_DEG=30                 # observability horizon limit

# ── Slack / email approval (optional; left blank = disabled) ────────────────
#CASSA_SLACK_BOT_TOKEN=xoxb-...
#CASSA_SLACK_APP_TOKEN=xapp-...
#CASSA_SLACK_CHANNEL=C0123456789
#CASSA_SMTP_HOST=
#CASSA_SMTP_PORT=587
#CASSA_SMTP_USER=
#CASSA_SMTP_PASSWORD=
#CASSA_SMTP_FROM=
#CASSA_SMTP_TO=
#CASSA_APPROVE_SECRET=change-me
#CASSA_API_BASE_URL=http://localhost:8000
